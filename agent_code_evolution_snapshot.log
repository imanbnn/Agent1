    await page.mouse.move(viewport['width'] / 2, viewport['height'] / 2)
    
    for _ in range(random.randint(3, 5)):
        pixels = random.randint(600, 900)
        while pixels > 0:
            step = min(pixels, random.randint(100, 250))
            # 1. Simulate mouse wheel 
            await page.mouse.wheel(0, step) 
            # 2. Force scroll on any virtualized containers found in GFS 
            await page.evaluate(f"""(s) => {{
                const containers = document.querySelectorAll('cdk-virtual-scroll-viewport, .scroll-container, main');
                window.scrollBy(0, s);
                containers.forEach(c => c.scrollBy(0, s));
            }}""", step)
            
            pixels -= step
            await asyncio.sleep(random.uniform(0.1, 0.3)) # Slower for Mac trackpad inertia
        await asyncio.sleep(random.uniform(1.0, 2.0))
    print("✅ Universal Scan complete.")

async def human_click(page, x, y):
    hx, hy = x + random.randint(-3, 3), y + random.randint(-3, 3)
    await page.mouse.move(hx, hy)
    await page.mouse.down()
    await asyncio.sleep(random.uniform(0.07, 0.18))
    await page.mouse.up()

