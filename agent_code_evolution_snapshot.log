    with open(manifest_path, "a") as manifest:
        manifest.write(f"\n\n# --- FULL ARCHITECTURE SNAPSHOT: {timestamp} ---\n")
        for file_path in files_to_track:
            if os.path.exists(file_path):
                with open(file_path, "r") as f:
