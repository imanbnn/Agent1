            break
        
        last_height = new_height
        print(f"📈 Page expanded... (New height: {new_height}px)")
        
    # 3. 💾 Save to Memory
    print(f"💾 Memorizing depth for {state}: {scrolls_taken} scrolls.")
    kb.learn(state, "scroll_depth", {"scrolls": scrolls_taken})

