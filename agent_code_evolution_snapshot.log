                log_event("STATE_CHANGE", {"from": last_state, "to": current_state})
                print(f"📍 State Changed -> {current_state}")
                
                if current_state not in ["transitioning", "unknown_page"]:
                    try:
                        await page.wait_for_load_state("networkidle", timeout=5000)
                    except: 
