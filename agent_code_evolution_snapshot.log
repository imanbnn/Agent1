async def teach_and_click(page, kb, state, element, action="click", value=None):
    coords = kb.get_coords(state, element)
    
    if not coords:
        selectors = {
            "username_field": 'input[name*="user" i], input[type="email"], #okta-signin-username, input[name="username"]',
            "password_field": 'input[type="password"], #okta-signin-password, input[name="password"]',
            "search_bar": 'input[type="search"], input[placeholder*="search" i]'
        }
        if element in selectors:
            loc = page.locator(selectors[element]).first
            try:
                # Wait up to 3 seconds for the element to physically appear
                await loc.wait_for(state="visible", timeout=3000)
