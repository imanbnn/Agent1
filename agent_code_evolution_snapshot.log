                if box:
                    coords = {"x": int(box["x"] + box["width"]/2), "y": int(box["y"] + box["height"]/2)}
                    kb.learn(state, element, coords)
                    print(f"🎯 [VISION] Learned X/Y coordinates for {element}")
            except Exception as e:
                print(f"⚠️ [VISION] Could not map coordinates for {element}. Is it blocked or missing?")

    if coords:
        print(f"🖱️ Moving mouse to {element}...")
        await bezier_move(page, coords['x'], coords['y'])
        await human_click(page, coords['x'], coords['y'])
        
        if action in ["type", "type_no_enter"] and value:
