# --- 🧪 HUMAN PHYSICS ENGINE ---
async def bezier_move(page, end_x, end_y, steps=15):
    """Moves mouse in a curve with a randomized start point."""
    start_x, start_y = random.randint(0, 100), random.randint(0, 100)
    cp1_x = start_x + (end_x - start_x) * random.uniform(0.1, 0.4)
    cp1_y = start_y + (end_y - start_y) * random.uniform(0.1, 0.4)
    cp2_x = start_x + (end_x - start_x) * random.uniform(0.6, 0.9)
    cp2_y = start_y + (end_y - start_y) * random.uniform(0.6, 0.9)

    for i in range(steps + 1):
        t = i / steps
        x = (1-t)**3 * start_x + 3*(1-t)**2 * t * cp1_x + 3*(1-t) * t**2 * cp2_x + t**3 * end_x
        y = (1-t)**3 * start_y + 3*(1-t)**2 * t * cp1_y + 3*(1-t) * t**2 * cp2_y + t**3 * end_y
        await page.mouse.move(x, y)
        await asyncio.sleep(random.uniform(0.01, 0.02))

async def deep_human_scroll(page):
    """
    Universal scroll: Loops until page height stops increasing 
    to guarantee all lazy-loaded content is triggered and discovered.
    """
    print("📜 Performing Universal Deep Scan to trigger lazy loading...")
    
    # Hover center so wheel events hit the main body instead of dead margins
    viewport = page.viewport_size
    if viewport:
        await page.mouse.move(viewport['width'] / 2, viewport['height'] / 2)
    
    last_height = await page.evaluate("document.body.scrollHeight")
    
    max_scrolls = 20 # Safety limit to prevent infinite loops on bottomless feeds
    for _ in range(max_scrolls):
        pixels = random.randint(800, 1200)
        await page.mouse.wheel(0, pixels)
        
        # Force scroll on virtualized Angular containers (GFS uses these)
        await page.evaluate("""() => {
            const containers = document.querySelectorAll('cdk-virtual-scroll-viewport, .scroll-container, main');
            containers.forEach(c => c.scrollBy(0, 1000));
        }""")
        
        await asyncio.sleep(2.5) # Wait for the network/lazy-loaded content to fetch
        
        new_height = await page.evaluate("document.body.scrollHeight")
        
        # If the height hasn't changed, we hit the absolute bottom
        if new_height == last_height:
            print("✅ Verified: Reached the absolute bottom of the page.")
            break
        
        last_height = new_height
        print(f"📈 Lazy content loaded, page expanded... (New height: {new_height}px)")

